{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)",     "dest": "server/index.js" },
    { "src": "/product/(.*)", "dest": "server/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}
